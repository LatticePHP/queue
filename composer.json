{
    "name": "lattice/queue",
    "description": "Job queue system for LatticePHP",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../contracts"
        }
    ],
    "require": {
        "php": "^8.4",
        "lattice/contracts": "dev-main",
        "illuminate/queue": "^12.0",
        "illuminate/bus": "^12.0",
        "illuminate/container": "^12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "ext-pdo_sqlite": "*"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Queue\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Queue\\Tests\\": "tests/"
        }
    }
}
